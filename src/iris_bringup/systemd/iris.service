[Unit]
Description=Iris ROS 2 companion robot
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=iris
WorkingDirectory=/home/iris/iris_ws
Environment=ROS_DOMAIN_ID=42
Environment=IRIS_MODELS_DIR=/home/iris/iris_models
ExecStart=/bin/bash -lc 'source /opt/ros/humble/setup.bash && source /home/iris/iris_ws/install/setup.bash && ros2 launch iris_bringup full.launch.py simulate:=false use_face:=true use_camera:=true'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target